# JetNine — environment template
# Copy to .env.local (gitignored) and fill in values from Supabase dashboard.
# .env.example is committed; .env.local is not.

# ─── Supabase (Project Settings → API) ────────────────────────────────────
# Public — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secret — server-only, never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Postgres (Project Settings → Database → Connection string) ──────────
# Use the "Transaction" pooler URL (port 6543) for serverless workloads
# and the "Session" pooler (port 5432) for Drizzle migrations.
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ─── Email (optional — ships dark without keys) ───────────────────────────
# RESEND_API_KEY=re_...
# POSTMARK_SERVER_TOKEN=...
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=<auth token from Twilio console>
# TWILIO_SMS_FROM=+18885551234                   # E.164, a Twilio-owned number
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886     # WABA sender, or sandbox
#   Inbound webhook URL to register in Twilio:
#     POST https://YOUR_DOMAIN/api/twilio/inbound
#   No path-based secret here — Twilio signs the payload with HMAC-SHA1
#   over the URL + sorted form params using TWILIO_AUTH_TOKEN. The route
#   verifies before processing.
# INBOUND_EMAIL_SECRET=<32+-char-random>        # secret in the inbound
#   webhook URL: https://YOUR_DOMAIN/api/email/inbound/<INBOUND_EMAIL_SECRET>
#   Configure on Postmark Inbound Stream → Webhook URL. Without this
#   env var the endpoint returns 404 (disabled).
# EMAIL_FROM="JetNine <dispatch@jetnine.com>"   # required when a provider
#                                                 key is set; module throws
#                                                 at boot otherwise.
# DISPATCH_NOTIFY_EMAIL=dispatch@jetnine.com
# NEXT_PUBLIC_SITE_URL=https://jetnine.com      # used to build workbench
#                                                 URLs in dispatch alerts.

# ─── Stripe (optional — ships dark without keys) ─────────────────────────
# Server-only secret + webhook signing secret. Without these the Pay-now
# button on /account/invoices returns STRIPE_NOT_CONFIGURED and the
# webhook endpoint responds 503.
# STRIPE_SECRET_KEY=sk_test_...           (or sk_live_... in prod)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Endpoint URL to register with Stripe:  https://YOUR_DOMAIN/api/stripe/webhook
# Events to forward: checkout.session.completed, payment_intent.payment_failed,
#                    charge.refunded

# ─── Analytics & SEO verification ────────────────────────────────────────
# Plausible is cookieless and GDPR-safe — no consent banner needed.
# Sign up at https://plausible.io, add your domain, then set:
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jetnine.com
# Search Console: paste the meta-tag content here once Google generates it.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=<token-from-search-console>

# ─── Sentry (optional — ships dark without DSN) ──────────────────────────
# Server-side capture (instrumentation.ts):
# SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXXX.ingest.sentry.io/PROJECT_ID
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Client-side capture (instrumentation-client.ts) — browser-visible:
# NEXT_PUBLIC_SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXXX.ingest.sentry.io/PROJECT_ID
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload (only needed on Vercel for stack-trace de-minification):
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=jetnine-web
